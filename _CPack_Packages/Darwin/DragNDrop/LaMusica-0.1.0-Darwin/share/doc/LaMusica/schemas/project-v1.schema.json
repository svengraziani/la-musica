{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev.lamusica.schemas.project-v1",
  "title": "LaMusica Project Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "tempoMap",
    "timeSignatures",
    "markers",
    "assets",
    "tracks",
    "clips",
    "midiClips",
    "routing",
    "plugins",
    "automation",
    "mcpAuditLog"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "tempoMap": { "type": "array" },
    "timeSignatures": { "type": "array" },
    "markers": { "type": "array" },
    "assets": { "type": "array" },
    "tracks": { "type": "array" },
    "clips": { "type": "array" },
    "midiClips": { "type": "array" },
    "routing": { "type": "array" },
    "plugins": { "type": "array" },
    "automation": { "type": "array" },
    "mcpAuditLog": { "type": "array" }
  },
  "additionalProperties": false
}
