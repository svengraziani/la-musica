root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,hpp,mm,cmake}]
indent_style = space
indent_size = 4
max_line_length = 100

[CMakeLists.txt]
indent_style = space
indent_size = 2
max_line_length = 100

[*.md]
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

[*.{sh,zsh}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
max_line_length = 120
