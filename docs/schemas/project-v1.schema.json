{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev.lamusica.schemas.project-v3",
  "title": "LaMusica Project Manifest v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "projectSampleRate",
    "tempoMap",
    "timeSignatures",
    "markers",
    "assets",
    "tracks",
    "clips",
    "midiClips",
    "takeLanes",
    "comps",
    "routing",
    "plugins",
    "automation",
    "mcpAuditLog"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "name": { "type": "string", "minLength": 1 },
    "projectSampleRate": { "type": "number", "exclusiveMinimum": 0 },
    "tempoMap": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tempoEvent" }
    },
    "timeSignatures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/timeSignatureEvent" }
    },
    "markers": { "type": "array", "items": { "$ref": "#/$defs/marker" } },
    "assets": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
    "tracks": { "type": "array", "items": { "$ref": "#/$defs/track" } },
    "clips": { "type": "array", "items": { "$ref": "#/$defs/clip" } },
    "midiClips": { "type": "array", "items": { "$ref": "#/$defs/midiClip" } },
    "takeLanes": { "type": "array", "items": { "$ref": "#/$defs/takeLane" } },
    "comps": { "type": "array", "items": { "$ref": "#/$defs/comp" } },
    "routing": { "type": "array", "items": { "$ref": "#/$defs/routing" } },
    "trackMix": { "type": "array", "items": { "$ref": "#/$defs/trackMixState" } },
    "plugins": { "type": "array", "items": { "$ref": "#/$defs/plugin" } },
    "automation": { "type": "array", "items": { "$ref": "#/$defs/automationLane" } },
    "mcpAuditLog": { "type": "array", "items": { "$ref": "#/$defs/mcpAuditEntry" } }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1 },
    "sample": { "type": "integer", "minimum": 0 },
    "tempoEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samplePosition", "bpm"],
      "properties": {
        "samplePosition": { "$ref": "#/$defs/sample" },
        "bpm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "timeSignatureEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samplePosition", "numerator", "denominator"],
      "properties": {
        "samplePosition": { "$ref": "#/$defs/sample" },
        "numerator": { "type": "integer", "minimum": 1 },
        "denominator": { "type": "integer", "minimum": 1 }
      }
    },
    "marker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "samplePosition"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "samplePosition": { "$ref": "#/$defs/sample" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "relativePath", "mediaType"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "relativePath": { "type": "string", "minLength": 1 },
        "mediaType": { "type": "string", "minLength": 1 }
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "enum": ["audio", "midi", "instrument", "group", "return", "master"]
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "trackId",
        "type",
        "startSample",
        "lengthSamples",
        "sourceOffsetSamples",
        "fadeInSamples",
        "fadeOutSamples",
        "gainDb",
        "muted",
        "reversed",
        "assetId"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "trackId": { "$ref": "#/$defs/id" },
        "type": { "enum": ["audio", "midi", "pattern"] },
        "startSample": { "$ref": "#/$defs/sample" },
        "lengthSamples": { "$ref": "#/$defs/sample" },
        "sourceOffsetSamples": { "$ref": "#/$defs/sample" },
        "fadeInSamples": { "$ref": "#/$defs/sample" },
        "fadeOutSamples": { "$ref": "#/$defs/sample" },
        "gainDb": { "type": "number" },
        "muted": { "type": "boolean" },
        "reversed": { "type": "boolean" },
        "assetId": { "type": "string" }
      }
    },
    "midiClip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clipId", "dataId"],
      "properties": {
        "clipId": { "$ref": "#/$defs/id" },
        "dataId": { "$ref": "#/$defs/id" }
      }
    },
    "takeLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clipId", "takes"],
      "properties": {
        "clipId": { "$ref": "#/$defs/id" },
        "takes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/take" } }
      }
    },
    "take": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "sourceOffsetSamples",
        "lengthSamples",
        "muted",
        "assetId"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "sourceOffsetSamples": { "$ref": "#/$defs/sample" },
        "lengthSamples": { "type": "integer", "minimum": 1 },
        "muted": { "type": "boolean" },
        "assetId": { "type": "string" }
      }
    },
    "comp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clipId", "segments"],
      "properties": {
        "clipId": { "$ref": "#/$defs/id" },
        "segments": { "type": "array", "items": { "$ref": "#/$defs/compSegment" } }
      }
    },
    "compSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["takeId", "clipStartSample", "lengthSamples", "takeSourceOffsetSamples"],
      "properties": {
        "takeId": { "$ref": "#/$defs/id" },
        "clipStartSample": { "$ref": "#/$defs/sample" },
        "lengthSamples": { "type": "integer", "minimum": 1 },
        "takeSourceOffsetSamples": { "$ref": "#/$defs/sample" }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceTrackId", "destinationTrackId"],
      "properties": {
        "sourceTrackId": { "$ref": "#/$defs/id" },
        "destinationTrackId": { "$ref": "#/$defs/id" }
      }
    },
    "trackMixState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trackId", "volumeDb", "pan", "muted", "solo"],
      "properties": {
        "trackId": { "$ref": "#/$defs/id" },
        "volumeDb": { "type": "number", "minimum": -120, "maximum": 24 },
        "pan": { "type": "number", "minimum": -1, "maximum": 1 },
        "muted": { "type": "boolean" },
        "solo": { "type": "boolean" }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "trackId", "format", "identifier"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "trackId": { "$ref": "#/$defs/id" },
        "format": { "type": "string", "minLength": 1 },
        "identifier": { "type": "string", "minLength": 1 }
      }
    },
    "automationLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetId", "parameterId", "mode", "defaultValue", "regions"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "targetKind": { "enum": ["mixer", "plugin", "instrument", "clip"] },
        "targetId": { "$ref": "#/$defs/id" },
        "parameterId": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["off", "read", "write", "touch", "latch", "trim"] },
        "defaultValue": { "type": "number" },
        "regions": { "type": "array", "items": { "$ref": "#/$defs/automationRegion" } }
      }
    },
    "automationRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startSample", "endSample", "points"],
      "properties": {
        "startSample": { "$ref": "#/$defs/sample" },
        "endSample": { "$ref": "#/$defs/sample" },
        "points": { "type": "array", "items": { "$ref": "#/$defs/automationPoint" } }
      }
    },
    "automationPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samplePosition", "value", "curveToNext"],
      "properties": {
        "samplePosition": { "$ref": "#/$defs/sample" },
        "value": { "type": "number" },
        "curveToNext": { "enum": ["step", "linear"] }
      }
    },
    "mcpAuditEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "toolName", "capability"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "toolName": { "type": "string", "minLength": 1 },
        "capability": { "type": "string", "minLength": 1 }
      }
    }
  }
}
